from pathlib import Path

# configfile: "colliderml_dev/configs_development/testing_and_validation/snakemake_test.yaml" # Remove this default

# Get optional parameters with defaults
seed = config.get("seed", None)
output_subdir = config.get("output_subdir", None)

# Define output directory structure
OUTPUT_DIR = Path(config["output"])
if output_subdir:
    OUTPUT_DIR = OUTPUT_DIR / output_subdir

# Get digi/reco flags
digi_enabled = config.get("digi", True)
reco_enabled = config.get("reco", False)
vertexing_enabled = config.get("vertexing", False)
output_root = config.get("output_root", True)

rule all:
    input:
        # Only require digitization outputs if digi=True
        [OUTPUT_DIR / "simhits.root", OUTPUT_DIR / "measurements.root", OUTPUT_DIR / "particles.root"] if digi_enabled and output_root else []
        # Add reconstruction outputs if reco=True
        + ([OUTPUT_DIR / "tracksummary_ckf.root", OUTPUT_DIR / "tracksummary_ambi.root"] if reco_enabled and output_root else [])
        + ([OUTPUT_DIR / "vertices.root"] if reco_enabled and vertexing_enabled and output_root else [])

rule generate_pythia:
    output:
        signal = OUTPUT_DIR / "events.hepmc3",
        pileup = OUTPUT_DIR / "events_pileup.hepmc3"
    params:
        config_path = workflow.configfiles[0],
        seed_arg = lambda wildcards: f"--seed {seed}" if seed is not None else "",
        subdir_arg = lambda wildcards: f"--output-subdir {output_subdir}" if output_subdir else ""
    benchmark:
        str(OUTPUT_DIR / "benchmarks/generate_pythia.tsv")
    log:
        str(OUTPUT_DIR / "logs/pythia_gen.log")
    shell:
        """
        mkdir -p {OUTPUT_DIR}/logs {OUTPUT_DIR}/benchmarks && \
        python colliderml_dev/scripts/simulation/pythia_gen.py \
            --config {params.config_path} \
            {params.seed_arg} \
            {params.subdir_arg} \
            2>&1 | tee {log}
        """

rule merge_and_smear:
    input:
        signal = rules.generate_pythia.output.signal,
        pileup = rules.generate_pythia.output.pileup
    output:
        merged = OUTPUT_DIR / "merged_events.hepmc3"
    params:
        config_path = workflow.configfiles[0],
        seed_arg = lambda wildcards: f"--seed {seed}" if seed is not None else "",
        subdir_arg = lambda wildcards: f"--output-subdir {output_subdir}" if output_subdir else ""
    benchmark:
        str(OUTPUT_DIR / "benchmarks/merge_and_smear.tsv")
    log:
        str(OUTPUT_DIR / "logs/merge_smear.log")
    shell:
        """
        python colliderml_dev/scripts/simulation/merge_and_smear.py \
            --config {params.config_path} \
            {params.seed_arg} \
            {params.subdir_arg} \
            2>&1 | tee {log}
        """

rule ddsim:
    input:
        merged = rules.merge_and_smear.output.merged
    output:
        edm4hep = OUTPUT_DIR / "edm4hep.root"
    params:
        config_path = workflow.configfiles[0],
        seed_arg = lambda wildcards: f"--seed {seed}" if seed is not None else "",
        subdir_arg = lambda wildcards: f"--output-subdir {output_subdir}" if output_subdir else ""
    benchmark:
        str(OUTPUT_DIR / "benchmarks/ddsim.tsv")
    log:
        str(OUTPUT_DIR / "logs/ddsim.log")
    shell:
        """
        python colliderml_dev/scripts/simulation/ddsim_run.py \
            --config {params.config_path} \
            {params.seed_arg} \
            {params.subdir_arg} \
            2>&1 | tee {log}
        """

rule digi_and_reco:
    input:
        edm4hep = rules.ddsim.output.edm4hep
    output:
        # Only require digitization outputs if digi=True
        digits = [
            OUTPUT_DIR / "simhits.root",
            OUTPUT_DIR / "measurements.root",
            OUTPUT_DIR / "particles.root"
        ] if digi_enabled and output_root else [],
        # Add reconstruction outputs if reco=True
        tracks = OUTPUT_DIR / "tracks.root" if reco_enabled and output_root else [],
        vertices = OUTPUT_DIR / "vertices.root" if reco_enabled and output_root else []
    params:
        config_path = workflow.configfiles[0],
        seed_arg = lambda wildcards: f"--seed {seed}" if seed is not None else "",
        subdir_arg = lambda wildcards: f"--output-subdir {output_subdir}" if output_subdir else ""
    benchmark:
        str(OUTPUT_DIR / "benchmarks/digi_and_reco.tsv")
    log:
        str(OUTPUT_DIR / "logs/digi_reco.log")
    shell:
        """
        python colliderml_dev/scripts/simulation/digi_and_reco.py \
            --config {params.config_path} \
            {params.seed_arg} \
            {params.subdir_arg} \
            2>&1 | tee {log}
        """
