# ColliderML backend environment variables.
#
# Copy to `.env` for local dev (docker-compose reads it automatically) OR
# paste each value into the Render dashboard for production.
#
# Required:
#   DATABASE_URL  - Postgres DSN. For Supabase, use the "Connection string"
#                   from Project Settings → Database → Connection pooling →
#                   Session mode (asyncpg requires this, NOT transaction mode).
#
# Secrets: anything marked "sync=false" in render.yaml must be set manually
# in the Render dashboard (never commit real secrets to the repo).

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/colliderml

# --- Admin ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=dev-admin-token

# --- SFAPI (NERSC) — leave empty for mock mode ---
SFAPI_CLIENT_ID=
SFAPI_CLIENT_SECRET=
NERSC_PROJECT=
NERSC_USER=

# --- Container image ---
CONTAINER_IMAGE=ghcr.io/opendatadetector/sw:0.2.2_linux-ubuntu24.04_gcc-13.3.0
COLLIDERML_BRANCH=staging

# --- HuggingFace upload (service account) ---
HF_TOKEN=
HF_DATASET_ORG=

# --- SMTP (optional, leave empty to disable email notifications) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=colliderml@noreply.example

# --- GitHub webhook ---
GITHUB_WEBHOOK_SECRET=

# --- Misc ---
POLL_INTERVAL_SECONDS=60
